  {
   "attachments": {
    "87ce24ff-a2b2-40b0-a039-5abff63742aa.jpg": {
     "image/jpeg": ""
    }
   },
   "cell_type": "markdown",
   "id": "ae384d3e-e478-4175-a7d4-c036f38b4d55",
