    "    plt.contourf(w, b, losses,levels,alpha=0.5)\n",
    "    plt.scatter(w_model[:,0],w_model[:,1],c='r',marker='+')\n",
    "    plt.plot(w_model[:,0],w_model[:,1],c='r')\n",
    "    plt.xlabel('w')\n",
    "    plt.ylabel('b')\n",
    "    plt.title(title)\n",
    "    plt.show()\n",
    "def trace():\n",
