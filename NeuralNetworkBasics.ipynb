    "def cost_func(x):\n",
    "    return x**2 - 4 * x + 1\n",
    "\n",
    "def gradient(x):\n",
    "    return 2*x - 4\n",
    "\n",
    "def gradient_descent(gradient, start, learn_rate, max_iter, tol):\n",
    "    x = start\n",
    "    steps = [start] \n",
    "\n",
    "    for _ in range(max_iter):\n",
    "        diff = learn_rate * gradient(x)\n",
    "        if np.abs(diff) < tol:\n",
    "            break\n",
    "        x = x - diff\n",
    "        steps.append(x)\n",
    "\n",
    "    return x, steps\n",
    "\n",
    "\n",
